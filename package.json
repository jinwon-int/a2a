{
  "name": "@jinwon-int/a2a-plane-monorepo",
  "private": true,
  "description": "Private A2A Plane candidate for broker, adapter plugin, Docker runner, contracts, docs, and examples.",
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -ws",
    "check": "npm run release-gate",
    "smoke:quickstart": "npm run build && npm run check:quickstart-conformance && npm run test:release-gate",
    "release-gate": "node scripts/release-gate.mjs",
    "check:layout": "node scripts/check-layout.mjs",
    "check:packages": "node scripts/check-packages.mjs",
    "check:runner-import-smoke": "node scripts/check-runner-import-smoke.mjs",
    "check:terminal-brief-routing": "node scripts/check-terminal-brief-routing.mjs",
    "check:message-id-ack-boundary": "node scripts/check-message-id-ack-boundary.mjs",
    "check:compatibility-baselines": "node scripts/check-compatibility-baselines.mjs",
    "check:quickstart-conformance": "node scripts/check-quickstart-conformance.mjs",
    "check:no-diff-closeout-guidance": "node --test scripts/check-no-diff-closeout-guidance.test.mjs",
    "scan:public-readiness": "node scripts/public-readiness-scan.mjs",
    "scan:readiness-gates": "node scanner/readiness/fail-closed-gates.mjs --spec docs/readiness/fail-closed-gates.json",
    "a2a:source-dryrun": "node scripts/a2a-source-dryrun-aggregator.mjs --spec docs/dry-run/source-public-dryrun-schema.json",
    "a2a:source-dryrun:test": "node --test scripts/a2a-source-dryrun-aggregator.test.mjs",
    "a2a:approval-rehearsal": "node scripts/a2a-source-public-approval-rehearsal.mjs --spec docs/approval-rehearsal/source-public-approval-packet-schema.json",
    "a2a:approval-rehearsal:test": "node --test scripts/a2a-source-public-approval-rehearsal.test.mjs",
    "scan:external-secrets": "node scripts/external-secret-scan.mjs",
    "libero:public-preflight-closeout": "node scripts/libero-public-preflight-closeout.mjs",
    "test": "npm run check",
    "test:release-gate": "node --test scanner/readiness/fail-closed-gates.test.mjs scripts/check-compatibility-baselines.test.mjs scripts/libero-public-preflight-closeout.test.mjs scripts/check-no-diff-closeout-guidance.test.mjs scripts/check-quickstart-conformance.test.mjs scripts/check-message-id-ack-boundary.test.mjs scripts/check-team1-source-public-readiness-libero.test.mjs scripts/check-team1-evidence-nochange-hardening-libero.test.mjs scripts/check-team1-source-public-approval-packet-libero.test.mjs scripts/check-team1-source-dryrun-orchestrator-libero.test.mjs scripts/check-team1-source-public-approval-rehearsal-libero.test.mjs scripts/a2a-source-public-approval-rehearsal.test.mjs scripts/check-team1-yukson-source-public-approval-rehearsal-libero.test.mjs scripts/check-team2-source-public-approval-rehearsal.test.mjs scripts/check-team1-source-public-execution-orchestrator-libero.test.mjs scripts/a2a-source-public-execution-orchestrator.test.mjs scripts/check-team2-final-go-no-go-semantics-libero.test.mjs scripts/check-team1-ops-stability-standards-libero.test.mjs scripts/round-merge-preflight.test.mjs scripts/check-team2-terminal-brief-activation-libero.test.mjs",
    "test:conformance": "node test/conformance/check-contract-fixtures.mjs && node test/conformance/check-terminal-evidence-ack-boundary.mjs",
    "round:merge-preflight": "node scripts/round-merge-preflight.mjs",
    "a2a:execution-orchestrator": "node scripts/a2a-source-public-execution-orchestrator.mjs --spec docs/execution-orchestrator/source-public-execution-orchestrator-schema.json",
    "a2a:execution-orchestrator:test": "node --test scripts/a2a-source-public-execution-orchestrator.test.mjs",
    "a2a:team2-source-approval-rehearsal": "node scripts/a2a-team2-source-public-approval-rehearsal.mjs --spec docs/approval-rehearsal/team2-soonwook-source-public-approval-rehearsal-schema.json",
    "a2a:team2-source-approval-rehearsal:test": "node --test scripts/check-team2-source-public-approval-rehearsal.test.mjs",
    "a2a:final-go-nogo-gate": "node scripts/a2a-source-public-final-go-nogo-gate.mjs --spec docs/final-approval/source-public-final-go-nogo-gate-schema.json",
    "a2a:final-go-nogo-gate:test": "node --test scripts/a2a-source-public-final-go-nogo-gate.test.mjs"
  },
  "license": "MIT"
}
