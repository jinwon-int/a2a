{
  "name": "openclaw-plugin-a2a",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A2A Plane broker adapter plugin for OpenClaw hosts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs tests/*.test.ts",
    "test:gateway": "rm -rf dist && tsc -p tsconfig.gateway-verify.json && node --test test/*.test.mjs",
    "preflight:canary:receipt-gated": "scripts/canary-receipt-gated-preflight.sh",
    "prepack": "npm run build",
    "check": "npm test"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.49",
    "ajv": "^8.18.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "openclaw": "file:test/fixtures/openclaw",
    "typescript": "^5.9.3"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "default": "./dist/api.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./standalone-broker-client": {
      "types": "./dist/standalone-broker-client.d.ts",
      "default": "./dist/standalone-broker-client.js"
    },
    "./type-mapping": {
      "types": "./dist/type-mapping.d.ts",
      "default": "./dist/type-mapping.js"
    },
    "./plugin-id": {
      "types": "./dist/plugin-id.d.ts",
      "default": "./dist/plugin-id.js"
    },
    "./src/*": {
      "types": "./dist/src/*.d.ts",
      "default": "./dist/src/*.js"
    },
    "./openclaw.plugin.json": "./openclaw.plugin.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md",
    "docs/agent-card-discovery.md",
    "docs/a2a-agent-card.local.json",
    "docs/compatibility-matrix.md",
    "docs/public-stable-readiness.md",
    "docs/remote-handoff-visibility-policy.md",
    "docs/operator-terminal-notification-receipts.md",
    "docs/termux-mobile-smoke-test.md",
    "docs/termux-troubleshooting.md"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
