{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist",
    "declaration": false,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "./test/shims/openclaw-plugin-sdk.d.ts",
    "./index.ts",
    "./api.ts",
    "./plugin-id.ts",
    "./config.ts",
    "./standalone-broker-client.ts",
    "./type-mapping.ts",
    "./src/*.ts"
  ],
  "exclude": ["./node_modules/**", "./src/*.test.ts"]
}
