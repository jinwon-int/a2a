{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "./test/shims/openclaw-plugin-sdk.d.ts",
    "./*.ts",
    "./src/**/*.ts"
  ],
  "exclude": [
    "./dist/**",
    "./node_modules/**",
    "./**/*.test.ts",
    "./tests/**"
  ]
}
